# Variables de entorno — copia a .env (local) o ponlas en Railway → Variables

# production | development
NODE_ENV=production

# Railway asigna PORT automáticamente — no lo cambies en Railway
PORT=3000

# URL pública HTTPS (sin barra final)
# Railway: https://tu-app.up.railway.app  (Settings → Networking)
# Opcional si Railway expone RAILWAY_PUBLIC_DOMAIN — el servidor la detecta
PUBLIC_URL=https://tu-app.up.railway.app

# Discord OAuth — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=https://tu-app.up.railway.app/auth/discord/callback

# Obligatorio en producción:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Railway va detrás de proxy HTTPS
TRUST_PROXY=1
